<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Do not restore Room/SQLite databases on reinstall. -->
        <exclude domain="database" path="."/>
    </cloud-backup>
    <device-transfer>
        <!-- Avoid DB transfer during device-to-device restore. -->
        <exclude domain="database" path="."/>
    </device-transfer>
</data-extraction-rules>
