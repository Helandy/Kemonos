<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="main_prefs.xml"/>
        <include domain="sharedpref" path="auth_secure_prefs.xml"/>
        <include domain="file" path="datastore/settings.preferences_pb"/>
        <include domain="file" path="datastore/auth_prefs.preferences_pb"/>
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="."/>
        <include domain="file" path="."/>
    </device-transfer>
</data-extraction-rules>
